# Sudojo API Environment Variables
# Copy this file to .env.local and update with your values
# Priority: .env.local > .env > system environment

# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgres://username:password@localhost:5432/sudojo

# =============================================================================
# Server
# =============================================================================
# Port to run the server on (default: 3000)
PORT=3000

# =============================================================================
# Firebase Admin SDK
# =============================================================================
# Firebase project ID
FIREBASE_PROJECT_ID=

# Firebase service account client email
FIREBASE_CLIENT_EMAIL=

# Firebase service account private key (include the full key with \n for newlines)
FIREBASE_PRIVATE_KEY=

# =============================================================================
# Site Admin Access
# =============================================================================
# Comma-separated list of email addresses for site admin access.
# Site admins bypass subscription/rate limit checks and can access admin features.
# Example: admin@example.com,another@example.com
SITEADMIN_EMAILS=

# =============================================================================
# RevenueCat
# =============================================================================
# RevenueCat secret API key (from RevenueCat dashboard > Project Settings > API Keys)
REVENUECAT_API_KEY=

# =============================================================================
# Solver Service
# =============================================================================
# URL of the Sudoku solver service
SOLVER_URL=http://localhost:5000

# API key for admin access to solver endpoints (bypasses auth and rate limits)
# Generate a secure random string for production
SOLVER_API_KEY=

# =============================================================================
# Apple Sign In (for account deletion token revocation)
# =============================================================================
# Apple Services ID (e.g., com.sudobility.sudojo.web)
APPLE_CLIENT_ID=
# Apple Developer Team ID
APPLE_TEAM_ID=
# Key ID for the Sign in with Apple key
APPLE_KEY_ID=
# The .p8 private key content (include full PEM format)
APPLE_PRIVATE_KEY=

# =============================================================================
# Solution Encryption
# =============================================================================
# AES-256-GCM encryption key for encrypting solution fields (hex-encoded, 64 chars)
# Generate with: openssl rand -hex 32
# Optional - if not set, solution encryption is skipped (passthrough for dev)
SOLUTION_ENCRYPTION_KEY=
